generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum ContractType {
  PERMANENT
  TEMPORARY
  INTERN
  WORKING_STUDENT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum DocumentCategory {
  CONTRACT
  PAYSLIP
  CERTIFICATE
  ID
  OTHER
}

enum ChecklistType {
  ONBOARDING
  OFFBOARDING
}

enum GoalStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  locale       String   @default("de")
  employee     Employee? @relation(fields: [employeeId], references: [id])
  employeeId   String?  @unique
  createdAt    DateTime @default(now())
}

model Employee {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  birthDate    DateTime?
  street       String?
  city         String?
  country      String?
  hireDate     DateTime
  exitDate     DateTime?
  contractType ContractType @default(PERMANENT)
  workload     Int      @default(100)
  status       EmployeeStatus @default(ACTIVE)
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?
  position     Position?   @relation(fields: [positionId], references: [id])
  positionId   String?
  location     Location?   @relation(fields: [locationId], references: [id])
  locationId   String?
  manager      Employee?   @relation("Reports", fields: [managerId], references: [id])
  managerId    String?
  reports      Employee[]  @relation("Reports")
  user         User?
  ledDepartments Department[] @relation("DeptLead")
  leaveRequests LeaveRequest[] @relation("EmployeeLeaves")
  leaveApprovals LeaveRequest[] @relation("LeaveApprovals")
  leaveEntitlements LeaveEntitlement[]
  timeEntries  TimeEntry[] @relation("EmployeeTime")
  documents    Document[] @relation("EmployeeDocs")
  employeeChecklists EmployeeChecklist[] @relation("EmployeeChecklists")
  goals        Goal[]      @relation("EmployeeGoals")
  reviews      Review[]    @relation("EmployeeReviews")
  reviewsGiven Review[]    @relation("ReviewerReviews")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Department {
  id       String @id @default(cuid())
  name     String @unique
  lead     Employee? @relation("DeptLead", fields: [leadId], references: [id])
  leadId   String?
  employees Employee[]
}

model Position {
  id    String @id @default(cuid())
  title String @unique
  employees Employee[]
}

model Location {
  id      String @id @default(cuid())
  name    String @unique
  city    String?
  country String?
  employees Employee[]
}

model LeaveType {
  id          String   @id @default(cuid())
  name        String   @unique
  colorHex    String
  paid        Boolean  @default(true)
  defaultDays Int      @default(0)
  requests     LeaveRequest[]
  entitlements LeaveEntitlement[]
}

model LeaveRequest {
  id           String      @id @default(cuid())
  employee     Employee    @relation("EmployeeLeaves", fields: [employeeId], references: [id])
  employeeId   String
  type         LeaveType   @relation(fields: [typeId], references: [id])
  typeId       String
  startDate    DateTime
  endDate      DateTime
  halfDayStart Boolean     @default(false)
  halfDayEnd   Boolean     @default(false)
  workingDays  Float
  reason       String?
  status       LeaveStatus @default(PENDING)
  approver     Employee?   @relation("LeaveApprovals", fields: [approverId], references: [id])
  approverId   String?
  decisionNote String?
  decidedAt    DateTime?
  createdAt    DateTime    @default(now())
}

model LeaveEntitlement {
  id         String    @id @default(cuid())
  employee   Employee  @relation(fields: [employeeId], references: [id])
  employeeId String
  type       LeaveType @relation(fields: [typeId], references: [id])
  typeId     String
  year       Int
  days       Float

  @@unique([employeeId, typeId, year])
}

model TimeEntry {
  id           String    @id @default(cuid())
  employee     Employee  @relation("EmployeeTime", fields: [employeeId], references: [id])
  employeeId   String
  date         DateTime
  start        DateTime
  end          DateTime?
  breakMinutes Int       @default(0)
  note         String?
  createdAt    DateTime  @default(now())

  @@index([employeeId, date])
}

model Document {
  id           String           @id @default(cuid())
  employee     Employee         @relation("EmployeeDocs", fields: [employeeId], references: [id])
  employeeId   String
  title        String
  category     DocumentCategory @default(OTHER)
  originalName String
  storedName   String           @unique
  mimeType     String
  sizeBytes    Int
  uploadedById String
  uploadedAt   DateTime         @default(now())

  @@index([employeeId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entity      String
  entityId    String
  changes     Json?
  createdAt   DateTime @default(now())
}

model ChecklistTemplate {
  id    String                  @id @default(cuid())
  name  String                  @unique
  type  ChecklistType           @default(ONBOARDING)
  items ChecklistTemplateItem[]
}

model ChecklistTemplateItem {
  id         String            @id @default(cuid())
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String
  title      String
  sortOrder  Int               @default(0)
}

model EmployeeChecklist {
  id          String          @id @default(cuid())
  employee    Employee        @relation("EmployeeChecklists", fields: [employeeId], references: [id])
  employeeId  String
  type        ChecklistType
  title       String
  createdAt   DateTime        @default(now())
  completedAt DateTime?
  tasks       ChecklistTask[]

  @@index([employeeId])
}

model ChecklistTask {
  id          String            @id @default(cuid())
  checklist   EmployeeChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId String
  title       String
  done        Boolean           @default(false)
  doneAt      DateTime?
  sortOrder   Int               @default(0)
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  authorId  String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pinned, createdAt])
}

model Goal {
  id          String     @id @default(cuid())
  employee    Employee   @relation("EmployeeGoals", fields: [employeeId], references: [id])
  employeeId  String
  title       String
  description String?
  status      GoalStatus @default(OPEN)
  progress    Int        @default(0)
  dueDate     DateTime?
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([employeeId])
}

model Review {
  id           String       @id @default(cuid())
  employee     Employee     @relation("EmployeeReviews", fields: [employeeId], references: [id])
  employeeId   String
  reviewer     Employee     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  reviewerId   String
  period       String
  status       ReviewStatus @default(DRAFT)
  rating       Int?
  strengths    String?
  improvements String?
  comments     String?
  createdAt    DateTime     @default(now())
  submittedAt  DateTime?

  @@index([employeeId])
}
