# Copy to .env.prod on the server and fill in real secrets. DO NOT commit .env.prod.
#   openssl rand -base64 32   # for each secret below

# Postgres password (used by the db service AND the app's DATABASE_URL)
POSTGRES_PASSWORD=change-me-strong-password

# Auth.js session signing secret
AUTH_SECRET=change-me-openssl-rand-base64-32
